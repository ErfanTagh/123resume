# Copy to .env and fill in the values:  cp .env.example .env

# ── Django ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
DOMAIN=http://localhost:5173

# ── MongoDB ──────────────────────────────────────────────
MONGODB_HOST=mongodb          # docker service name (use 127.0.0.1 for local, non-Docker)
MONGODB_PORT=27017
MONGODB_NAME=resume_db
MONGODB_USERNAME=
MONGODB_PASSWORD=

# ── AI features (optional) ───────────────────────────────
# Without a key the app still runs; AI endpoints just return 503.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Email (SMTP — works with SendGrid, Gmail, etc.) ──────
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── Mailgun (optional — used for broadcast/announcement email) ──
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=https://api.mailgun.net

# ── Social login (all optional) ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
